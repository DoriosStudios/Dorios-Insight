				}
			},
			{
				"hunger_buffer_bar@insight_hud.hunger_buffer_bar": {
					"anchor_from": "bottom_right",
					"anchor_to": "bottom_right",
					"offset": [0, -32],
					"layer": -10,
					"bindings": [
						{
							"binding_name": "#show_survival_ui"
						}
					]
				}
			},
			{
				"saturation_bar@insight_hud.saturation_bar": {
					"anchor_from": "bottom_right",
					"anchor_to": "bottom_right",
					"offset": [0, -32],
					"layer": 3,
					"bindings": [
						{
							"binding_name": "#show_survival_ui"
						}
					]
				}
			}
