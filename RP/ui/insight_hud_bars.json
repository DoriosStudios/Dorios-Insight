	"health_numeric_indicator": {
		"type": "stack_panel",
		"orientation": "horizontal",
		"size": ["100%cm", "100%cm"],
		"controls": [
			{
				"icon": {
					"type": "panel",
					"size": [8, 9],
					"controls": [
						{
							"full@insight_hud.health_img_full": {
								"bindings": [
									{
										"binding_type": "view",
										"source_control_name": "section_a",
										"source_property_name": "(#health > 1)",
										"target_property_name": "#visible"
									}
								]
							}
						},
						{
							"half@insight_hud.health_img_half": {
								"bindings": [
									{
										"binding_type": "view",
										"source_control_name": "section_a",
										"source_property_name": "((#health > 0) and not(#health > 1))",
										"target_property_name": "#visible"
									}
								]
							}
						}
					]
				}
			},
			{
				"gap": {
					"type": "panel",
					"size": [4, 1]
				}
			},
			{
				"value_group": {
					"type": "stack_panel",
					"orientation": "horizontal",
					"size": ["100%cm", "100%cm"],
					"controls": [
						{
							"current": {
								"type": "label",
								"text": "#text",
								"shadow": true,
								"color": [1.0, 0.42, 0.42],
								"bindings": [
									{
										"binding_type": "view",
										"source_control_name": "section_a",
										"source_property_name": "#health",
										"target_property_name": "#text"
									}
								]
							}
						},
						{
							"current_gap": {
								"type": "panel",
								"size": [2, 1]
							}
						},
						{
							"slash": {
								"type": "label",
								"text": "/",
								"shadow": true,
								"color": [0.82, 0.82, 0.82]
							}
						},
						{
							"max_gap": {
								"type": "panel",
								"size": [2, 1]
							}
						},
						{
							"max": {
								"type": "label",
								"text": "#text",
								"shadow": true,
								"color": [1.0, 0.42, 0.42],
								"bindings": [
									{
										"binding_type": "view",
										"source_control_name": "section_a",
										"source_property_name": "#max_health",
										"target_property_name": "#text"
									}
								]
							}
						}
					]
				}
			}
		],
		"bindings": [
			{
				"binding_name": "#show_survival_ui"
			},
			{
				"binding_type": "view",
				"source_control_name": "section_e",
				"source_property_name": "(#hud_health_indicator > 0)",
				"target_property_name": "#indicator_enabled"
			},
			{
				"binding_type": "view",
				"source_control_name": "section_a",
				"source_property_name": "(#max_health > 0)",
				"target_property_name": "#has_data"
			},
			{
				"binding_type": "view",
				"source_property_name": "(#show_survival_ui and #indicator_enabled and #has_data)",
				"target_property_name": "#visible"
			}
		]
	},

