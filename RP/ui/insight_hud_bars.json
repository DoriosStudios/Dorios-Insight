			{ "section_d@insight_data.hud_data_section_d": {} },
			{ "section_e@insight_data.hud_data_section_e": {} }
		]
	},

	"centered_gui_elements": {
		"type": "panel",
		"anchor_from": "bottom_middle",
		"anchor_to": "bottom_middle",
		"size": [182, 60],
		"controls": [
			{
				"extra_armor_bar_panel": {
					"type": "stack_panel",
					"orientation": "vertical",
					"anchor_from": "bottom_left",
					"anchor_to": "bottom_left",
					"offset": [0, -51],
					"size": ["100%c", "100%c"],
					"controls": [
						{
							"extra_armor_bar@insight_hud.extra_armor_bar": {
								"layer": 10,
								"bindings": [
									{
										"binding_type": "view",
										"source_control_name": "section_c",
										"source_property_name": "(#extra_armor > 0)",
										"target_property_name": "#visible"
									}
								]
							}
						},
						{
							"gap": { "type": "panel", "size": [1, 1] }
						},
						{
							"extra_armor_full_factory@insight_hud.extra_armor_full_factory": {}
						},
						{
							"health_gap_factory@insight_hud.health_gap_factory": {}
						}
					],
					"bindings": [
						{
							"binding_name": "#show_survival_ui"
						},
						{
							"binding_type": "view",
							"source_control_name": "section_c",
							"source_property_name": "(#extra_armor + #extra_armor_full)",
							"target_property_name": "#total_extra"
						},
						{
							"binding_type": "view",
							"source_property_name": "(#show_survival_ui and (#total_extra > 0))",
							"target_property_name": "#visible"
						}
					]
				}
			},
			{
				"health_numeric_indicator@insight_hud.health_numeric_indicator": {
					"anchor_from": "bottom_left",
					"anchor_to": "bottom_left",
					"offset": [0, -62]
				}
			},
			{
				"toughness_bar@insight_hud.toughness_bar": {
					"anchor_from": "bottom_left",
					"anchor_to": "bottom_left",
					"offset": [-9, -42],
